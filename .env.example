# ── LLM ────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-...

# ── LangSmith (observability + evaluaciones) ───────
LANGCHAIN_API_KEY=lsv2_pt_...
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=01-agentic-rag   # proyecto de trazas

# ── Neo4j (GraphRAG) ───────────────────────────────
# Usar bolt:// NO neo4j:// (evita routing protocol error)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_password

# ── CSVs Northwind (ruta relativa desde repo root) ─
CATEGORY_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/categories.csv
PRODUCT_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/products.csv
SUPPLIER_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/suppliers.csv
ORDER_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/orders.csv
ORDER_DETAILS_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/order_details.csv
SHIPPERS_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/shippers.csv
EMPLOYEE_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/employees.csv
CUSTOMER_CSV_FILE_PATH=neo4j_graphrag_tutorial/data/customers.csv
